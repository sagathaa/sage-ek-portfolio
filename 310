<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sage Ek Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F5F0E8;
    --dark: #1a1a1a;
    --rust: #C4522A;
    --sage: #8A9B7A;
    --sand: #D4B896;
    --black: #0d0d0d;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  #work, #skills, #edu, #contact { scroll-margin-top: 20px; }

  body {
    background: var(--cream);
    color: var(--dark);
    font-family: 'DM Mono', monospace;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 2rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60vw;
    height: 60vw;
    border-radius: 50%;
    border: 1px solid var(--sand);
    opacity: 0.4;
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 10%;
    left: -15%;
    width: 40vw;
    height: 40vw;
    border-radius: 50%;
    border: 1px solid var(--rust);
    opacity: 0.2;
    pointer-events: none;
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .nav a {
    color: var(--dark);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .nav a:hover { opacity: 1; }

  .hero-center {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 3rem 0 2rem;
    position: relative;
  }

  .name-block {
    position: relative;
    z-index: 2;
  }

  .name-block h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(5rem, 20vw, 12rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--dark);
  }

  .name-block h1 span {
    color: var(--rust);
  }

  .subtitle {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(1rem, 3vw, 1.4rem);
    color: var(--rust);
    margin-top: 1rem;
    letter-spacing: 0.05em;
  }

  .hero-photo {
    position: absolute;
    right: -1rem;
    bottom: -2rem;
    width: clamp(160px, 45vw, 280px);
    z-index: 1;
    opacity: 0.9;
    mix-blend-mode: multiply;
  }

  .hero-photo img {
    width: 100%;
    display: block;
    filter: grayscale(20%) contrast(1.05);
  }

  .tape {
    position: absolute;
    background: rgba(212, 184, 150, 0.6);
    transform: rotate(-2deg);
    pointer-events: none;
  }

  .tape-1 {
    width: 80px;
    height: 22px;
    top: -8px;
    left: 30%;
  }

  .scroll-hint {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.4;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-hint::after {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background: var(--dark);
  }

  /* ABOUT STRIP */
  .about-strip {
    background: var(--dark);
    color: var(--cream);
    padding: 3rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .about-strip::before {
    content: 'EXPERIENCE DESIGN & MANAGEMENT';
    position: absolute;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 8rem;
    opacity: 0.04;
    white-space: nowrap;
    top: 50%;
    left: -5%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .about-inner {
    max-width: 600px;
  }

  .label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 1rem;
  }

  .about-strip p {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.1rem, 3.5vw, 1.5rem);
    line-height: 1.6;
    font-weight: 400;
  }

  .about-strip p em {
    color: var(--sand);
    font-style: italic;
  }

  .stats-row {
    display: flex;
    gap: 2rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    color: var(--rust);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  /* SECTION HEADERS */
  .section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 2.5rem 1.5rem 1.5rem;
  }

  .section-header .num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 4rem;
    color: var(--sand);
    line-height: 1;
    opacity: 0.6;
  }

  .section-header .title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 8vw, 3.5rem);
    line-height: 1;
    letter-spacing: 0.02em;
  }

  /* PROJECT CARDS */
  .projects {
    padding: 0 1.5rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project-card {
    background: white;
    position: relative;
    overflow: hidden;
    box-shadow: 4px 4px 0 var(--dark);
    border: 1px solid var(--dark);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .project-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 var(--dark);
  }

  .project-card.rotated {
    transform: rotate(-1.5deg);
  }

  .project-card.rotated:hover {
    transform: rotate(-1.5deg) translate(-3px, -3px);
    box-shadow: 7px 7px 0 var(--dark);
  }

  .project-card.rotated-right {
    transform: rotate(1deg);
  }

  .project-card.rotated-right:hover {
    transform: rotate(1deg) translate(-3px, -3px);
    box-shadow: 7px 7px 0 var(--dark);
  }

  .card-images {
    display: grid;
    gap: 0;
  }

  .card-images.two-col {
    grid-template-columns: 1fr 1fr;
  }

  .card-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  .card-img.tall {
    aspect-ratio: 3/4;
  }

  .card-img.wide {
    aspect-ratio: 16/9;
  }

  .card-body {
    padding: 1.5rem;
    background: var(--cream);
  }

  .card-tag {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: var(--dark);
    color: var(--cream);
    display: inline-block;
    padding: 0.25rem 0.6rem;
    margin-bottom: 0.8rem;
  }

  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.4rem, 5vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .card-desc {
    font-size: 0.75rem;
    line-height: 1.7;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .card-metrics {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .metric {
    display: flex;
    flex-direction: column;
  }

  .metric-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    color: var(--rust);
    line-height: 1;
  }

  .metric-label {
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  /* SLOPE SCHOOL CARD */
  .slope-card {
    background: var(--dark);
    color: var(--cream);
  }

  .slope-card .card-body {
    background: var(--dark);
    color: var(--cream);
  }

  .slope-card .card-tag {
    background: var(--sage);
    color: var(--dark);
  }

  .slope-card .card-desc {
    color: var(--cream);
    opacity: 0.7;
  }

  .slope-card .metric-val {
    color: var(--sage);
  }

  /* DECORATIVE ELEMENTS */
  .scissors {
    text-align: center;
    padding: 1rem 0;
    font-size: 1.2rem;
    opacity: 0.3;
    letter-spacing: 0.5rem;
  }

  .dashed-line {
    border: none;
    border-top: 2px dashed;
    border-color: var(--sand);
    opacity: 0.4;
    margin: 0 1.5rem;
  }

  .sticker {
    display: inline-block;
    background: var(--rust);
    color: var(--cream);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    padding: 0.4rem 0.8rem;
    border-radius: 100px;
    transform: rotate(-3deg);
  }

  /* SKILLS SECTION */
  .skills-section {
    background: var(--sand);
    padding: 3rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .skills-section::before {
    content: '✦';
    position: absolute;
    font-size: 15rem;
    opacity: 0.06;
    top: -3rem;
    right: -3rem;
    pointer-events: none;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }

  .skill-pill {
    background: var(--dark);
    color: var(--cream);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.7rem 1rem;
    text-align: center;
    transition: background 0.2s, transform 0.2s;
  }

  .skill-pill:hover {
    background: var(--rust);
    transform: scale(1.02);
  }

  .skill-pill.light {
    background: var(--cream);
    color: var(--dark);
    border: 1px solid var(--dark);
  }

  .skill-pill.light:hover {
    background: var(--rust);
    color: var(--cream);
    border-color: var(--rust);
  }

  /* EDUCATION */
  .edu-section {
    padding: 2.5rem 1.5rem 3rem;
  }

  .edu-card {
    border: 1px solid var(--dark);
    padding: 1.5rem;
    margin-top: 1.5rem;
    position: relative;
  }

  .edu-card::before {
    content: '🎓';
    position: absolute;
    top: -0.8rem;
    left: 1rem;
    background: var(--cream);
    padding: 0 0.4rem;
    font-size: 1rem;
  }

  .edu-school {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .edu-degree {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-top: 0.3rem;
  }

  .courses {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .course-tag {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    border: 1px solid var(--dark);
    padding: 0.25rem 0.5rem;
    opacity: 0.7;
  }

  /* FOOTER / CONTACT */
  .contact-section {
    background: var(--dark);
    color: var(--cream);
    padding: 4rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .contact-section::before {
    content: 'SAGE EK';
    position: absolute;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 12rem;
    opacity: 0.04;
    white-space: nowrap;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    letter-spacing: 0.1em;
  }

  .contact-big {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 10vw, 6rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
  }

  .contact-big span {
    color: var(--rust);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    align-items: center;
  }

  .contact-link {
    color: var(--cream);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    opacity: 0.7;
    transition: opacity 0.2s, color 0.2s;
  }

  .contact-link:hover {
    opacity: 1;
    color: var(--sand);
  }

  .contact-link::before {
    content: '→';
    font-size: 0.9rem;
  }

  .footer-note {
    margin-top: 3rem;
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.25;
  }

  /* COLLAGE CUTOUT */
  .cutout-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 8rem;
    position: absolute;
    line-height: 1;
    pointer-events: none;
  }

  /* MARQUEE */
  .marquee-strip {
    background: var(--rust);
    color: var(--cream);
    padding: 0.6rem 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .marquee-inner {
    display: inline-block;
    animation: marquee 18s linear infinite;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.2em;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* FADE IN */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 600px) {
    .hero-photo {
      right: 1rem;
      bottom: -1rem;
      width: 300px;
    }
    .projects {
      padding: 0 2rem 4rem;
    }
  }
</style>
</head>
